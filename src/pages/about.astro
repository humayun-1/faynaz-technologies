---
import SiteClean from "../components/SiteClean.astro";
import { site } from "../data/site";

const title = "About Faynaz Technologies — Software, DevOps & AI Automation Studio in Dubai";
const description =
  "Faynaz Technologies is a Dubai-based software studio building full-stack development, DevOps, and AI automation — as a dedicated team or a managed service, for clients across the UK, Europe, Australia, Singapore, and the US.";

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site.url}/` },
    { "@type": "ListItem", position: 2, name: "About", item: `${site.url}/about` },
  ],
};
const aboutPage = {
  "@type": "AboutPage",
  "@id": `${site.url}/about#webpage`,
  url: `${site.url}/about`,
  name: title,
  about: { "@id": `${site.url}/#organization` },
  isPartOf: { "@id": `${site.url}/#website` },
};
---

<SiteClean title={title} description={description} canonical="/about" schema={[breadcrumb, aboutPage]}>
  <section class="fx-subhero">
    <div class="fx-wrap">
      <nav class="fx-crumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>About</span></nav>
      <p class="fx-eyebrow">About Faynaz Technologies</p>
      <h1>A Dubai-based software, DevOps &amp; AI automation studio.</h1>
      <p class="fx-lead">We help startups, SMEs, and enterprises build and run software that earns its place in the business — delivered by senior engineers as a dedicated team or a managed service, with none of the agency overhead.</p>
      <div class="fx-subhero-actions">
        <a href="/contact" class="fx-btn fx-btn--primary"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
        <a href="/service" class="fx-btn fx-btn--ghost"><span>Explore services</span></a>
      </div>
    </div>
  </section>

  <!-- machine + human readable facts (strong GEO/entity signal) -->
  <section class="fx-section fx-section--plain" style="padding-top:clamp(40px,5vw,64px)">
    <div class="fx-wrap">
      <dl class="fx-facts fx-reveal">
        <div><dt>Headquarters</dt><dd>Dubai, UAE</dd></div>
        <div><dt>Focus</dt><dd>Software · DevOps · AI</dd></div>
        <div><dt>Engagement</dt><dd>Dedicated team or managed service</dd></div>
        <div><dt>Clients across</dt><dd>UK · EU · AU · SG · US</dd></div>
      </dl>
    </div>
  </section>

  <section class="fx-section fx-section--surface">
    <div class="fx-wrap fx-why-grid">
      <div class="fx-head fx-reveal" style="margin-bottom:0">
        <p class="fx-eyebrow">Who we are</p>
        <h2>Engineering that starts from the business outcome.</h2>
        <p>We are a focused studio, not a large agency. The people who plan your work are the people who build it.</p>
      </div>
      <div class="fx-prose fx-reveal">
        <p>Faynaz Technologies is a software studio headquartered in <strong>Jumeirah Lake Towers, Dubai</strong>. We design, build, and operate three things: <strong>full-stack products</strong> (web apps, SaaS platforms, MVPs and APIs), <strong>DevOps and cloud</strong> (CI/CD, Kubernetes, cloud migration, infrastructure as code), and <strong>AI automation</strong> (workflow automation, AI agents, and LLM integration).</p>
        <p>You can work with us two ways. Hire a <strong>dedicated team</strong> of senior engineers who plug into your organisation on a monthly retainer, or hand us a <strong>managed service</strong> engagement where we scope, build, and deliver a defined outcome at a fixed price. Either way, you own the code and the infrastructure from day one.</p>
        <p>We keep the team deliberately small and senior so delivery stays fast, communication stays direct, and quality stays high — the traits that matter to founders, SMEs, and enterprise teams alike.</p>
        <p>Find us on <a href={site.social.clutch} target="_blank" rel="noopener noreferrer">Clutch</a> and <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>.</p>
      </div>
    </div>
  </section>

  <section class="fx-section">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal">
        <p class="fx-eyebrow">How we operate</p>
        <h2>Principles that keep delivery predictable.</h2>
      </div>
      <div class="fx-cards fx-reveal">
        <div class="fx-card"><h3>Senior-only delivery</h3><p>The engineers and lead you meet on the first call are the ones who ship. Work is never handed to a junior bench after signing.</p></div>
        <div class="fx-card"><h3>Fixed scope, no surprises</h3><p>We agree scope and price after a short discovery, then hold to the plan and the dates.</p></div>
        <div class="fx-card"><h3>You own everything</h3><p>Repository, cloud accounts, and IP are yours from day one — clean, documented, and free of lock-in.</p></div>
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--surface">
    <div class="fx-wrap">
      <div class="fx-cta fx-reveal">
        <p class="fx-eyebrow">Work with us</p>
        <h2>Let's scope your next release.</h2>
        <p>Tell us what you're trying to move. We'll come back with an honest plan, a timeline, and a fixed price.</p>
        <div class="fx-cta-actions">
          <a href="/contact" class="fx-btn fx-btn--light"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
          <a href="/service" class="fx-btn fx-btn--outline-light"><span>See services</span></a>
        </div>
      </div>
    </div>
  </section>
</SiteClean>
