---
import SiteClean from "../../components/SiteClean.astro";
import { site } from "../../data/site";
import { servicePillars, otherServices } from "../../data/services";

export function getStaticPaths() {
  return servicePillars.map((s) => ({ params: { slug: s.slug }, props: { svc: s } }));
}

const { svc } = Astro.props;
const path = `/services/${svc.slug}`;
const title = `${svc.h1} | Faynaz Technologies`;
const others = otherServices(svc.slug);

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site.url}/` },
    { "@type": "ListItem", position: 2, name: "Services", item: `${site.url}/service` },
    { "@type": "ListItem", position: 3, name: svc.name, item: `${site.url}${path}` },
  ],
};
const service = {
  "@type": "Service",
  name: svc.h1,
  serviceType: svc.name,
  description: svc.description,
  provider: { "@id": `${site.url}/#organization` },
  areaServed: site.areaServed,
};
const faqSchema = {
  "@type": "FAQPage",
  mainEntity: svc.faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
---

<SiteClean title={title} description={svc.description} canonical={path} schema={[breadcrumb, service, faqSchema]}>
  <section class="fx-subhero">
    <div class="fx-wrap">
      <nav class="fx-crumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><a href="/service">Services</a><span class="sep">/</span><span>{svc.name}</span></nav>
      <p class="fx-eyebrow">Services</p>
      <h1>{svc.h1}</h1>
      <p class="fx-lead">{svc.intro}</p>
      <div class="fx-subhero-actions">
        <a href="/contact" class="fx-btn fx-btn--primary"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
        <a href="/#estimate" class="fx-btn fx-btn--ghost"><span>Estimate your project</span></a>
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--plain" style="padding-top:clamp(40px,5vw,64px)">
    <div class="fx-wrap fx-guide">
      <div class="fx-prose">
        <h2>What's included</h2>
        <ul>
          {svc.deliverables.map((d) => <li>{d}</li>)}
        </ul>
        <h2>Technologies we use</h2>
        <div class="fx-chips">
          {svc.tech.map((t) => <span class="fx-chip">{t}</span>)}
        </div>
        <h2 style="margin-top:34px">How we work</h2>
        <ul>
          <li><strong>Discover</strong> — we map the goal and success metric before any code.</li>
          <li><strong>Design &amp; scope</strong> — a fixed plan and price, agreed up front.</li>
          <li><strong>Build &amp; ship</strong> — senior engineers deliver in short cycles with QA built in.</li>
          <li><strong>Launch &amp; support</strong> — we go live, watch the numbers, and keep it healthy.</li>
        </ul>
      </div>

      <div class="fx-inline-cta">
        <p>Need {svc.name.toLowerCase()}?<span>Hire a dedicated team, or hand us a fixed-scope build.</span></p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <a href="/#estimate" class="fx-btn fx-btn--ghost"><span>Estimate</span></a>
          <a href="/contact" class="fx-btn fx-btn--primary"><span>Let's have a call</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--surface" id="faq">
    <div class="fx-wrap fx-faq-grid">
      <div class="fx-head fx-reveal" style="margin-bottom:0"><p class="fx-eyebrow">FAQ</p><h2>{svc.name}, answered.</h2></div>
      <div class="fx-reveal">
        {svc.faqs.map((f, i) => (
          <details class="fx-faq" open={i === 0}>
            <summary><span>{f.q}</span><span class="plus" aria-hidden="true"></span></summary>
            <div class="ans">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="fx-section" aria-label="Other services">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal" style="margin-bottom:32px"><p class="fx-eyebrow">More services</p><h2 style="font-size:clamp(1.5rem,3vw,2rem)">Explore the other pillars</h2></div>
      <div class="fx-cards fx-reveal">
        {others.map((o) => (
          <a class="fx-card" href={`/services/${o.slug}`}>
            <h3>{o.name}</h3>
            <p>{o.description}</p>
            <span class="more">Learn more <span aria-hidden="true">→</span></span>
          </a>
        ))}
        <a class="fx-card" href="/hire">
          <h3>Hire engineers</h3>
          <p>Add senior DevOps, AI, and full-stack engineers to your team on a monthly retainer.</p>
          <span class="more">View roles <span aria-hidden="true">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--surface">
    <div class="fx-wrap">
      <div class="fx-cta fx-reveal">
        <p class="fx-eyebrow">Start a project</p>
        <h2>Let's scope your {svc.name.toLowerCase()} project.</h2>
        <p>Tell us what you're building. We'll come back with an honest plan, a timeline, and a fixed price.</p>
        <div class="fx-cta-actions">
          <a href="/contact" class="fx-btn fx-btn--light"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
          <a href="/service" class="fx-btn fx-btn--outline-light"><span>All services</span></a>
        </div>
      </div>
    </div>
  </section>
</SiteClean>
