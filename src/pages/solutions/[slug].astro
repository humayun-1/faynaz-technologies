---
import SiteClean from "../../components/SiteClean.astro";
import { site } from "../../data/site";
import { solutions, relatedSolutions } from "../../data/solutions";

export function getStaticPaths() {
  return solutions.map((s) => ({ params: { slug: s.slug }, props: { solution: s } }));
}

const { solution } = Astro.props;
const path = `/solutions/${solution.slug}`;
const title = `${solution.h1} | Faynaz Technologies`;
const related = relatedSolutions(solution.slug);

const faqs = [
  ...solution.faqs,
  {
    q: `Do you offer ${solution.service.toLowerCase()} for ${solution.industry} as a dedicated team or a project?`,
    a: `Both. You can hire dedicated engineers who work as part of your team, or hand us a fixed-scope ${solution.service.toLowerCase()} engagement delivered end-to-end. You own the code and infrastructure either way.`,
  },
];

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site.url}/` },
    { "@type": "ListItem", position: 2, name: "Solutions", item: `${site.url}/solutions` },
    { "@type": "ListItem", position: 3, name: solution.h1, item: `${site.url}${path}` },
  ],
};
const service = {
  "@type": "Service",
  name: solution.h1,
  serviceType: `${solution.service} for ${solution.industry}`,
  description: solution.description,
  provider: { "@id": `${site.url}/#organization` },
  areaServed: site.areaServed,
  audience: { "@type": "Audience", audienceType: solution.industry },
};
const faqSchema = {
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
---

<SiteClean title={title} description={solution.description} canonical={path} schema={[breadcrumb, service, faqSchema]}>
  <section class="fx-subhero">
    <div class="fx-wrap">
      <nav class="fx-crumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><a href="/solutions">Solutions</a><span class="sep">/</span><span>{solution.h1}</span></nav>
      <p class="fx-eyebrow">{solution.category} · {solution.industry}</p>
      <h1>{solution.h1}</h1>
      <p class="fx-lead">{solution.intro}</p>
      <div class="fx-subhero-actions">
        <a href="/contact" class="fx-btn fx-btn--primary"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
        <a href="/#estimate" class="fx-btn fx-btn--ghost"><span>Estimate your project</span></a>
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--plain" style="padding-top:clamp(40px,5vw,64px)">
    <div class="fx-wrap fx-guide">
      <div class="fx-prose">
        <h2>The challenges in {solution.industry}</h2>
        <ul>
          {solution.pains.map((p) => <li>{p}</li>)}
        </ul>
        <h2 style="margin-top:34px">What we deliver</h2>
        <ul>
          {solution.deliverables.map((d) => <li>{d}</li>)}
        </ul>
        <h2>Why {solution.industry} teams work with Faynaz</h2>
        <ul>
          <li><strong>Senior engineers only</strong> — the people who plan the work are the ones who build it.</li>
          <li><strong>Real timezone overlap</strong> from Dubai with the UK, Europe, Australia, and Singapore.</li>
          <li><strong>You own everything</strong> — code, cloud accounts, and IP from day one.</li>
          <li><strong>Dedicated team or fixed-scope</strong> — pick the model that fits the project.</li>
        </ul>
      </div>

      <div class="fx-inline-cta">
        <p>Have a {solution.industry.toLowerCase()} project in mind?<span>Get a ballpark from the estimator, or book a call for a fixed quote.</span></p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <a href="/#estimate" class="fx-btn fx-btn--ghost"><span>Estimate</span></a>
          <a href="/contact" class="fx-btn fx-btn--primary"><span>Let's have a call</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--surface" id="faq">
    <div class="fx-wrap fx-faq-grid">
      <div class="fx-head fx-reveal" style="margin-bottom:0"><p class="fx-eyebrow">FAQ</p><h2>{solution.h1}, answered.</h2></div>
      <div class="fx-reveal">
        {faqs.map((f, i) => (
          <details class="fx-faq" open={i === 0}>
            <summary><span>{f.q}</span><span class="plus" aria-hidden="true"></span></summary>
            <div class="ans">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="fx-section" aria-label="Other solutions">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal" style="margin-bottom:32px"><p class="fx-eyebrow">Explore more</p><h2 style="font-size:clamp(1.5rem,3vw,2rem)">Other solutions</h2></div>
      <div class="fx-cards fx-reveal">
        {related.map((r) => (
          <a class="fx-card" href={`/solutions/${r.slug}`}>
            <p class="fx-eyebrow" style="margin-bottom:12px">{r.category} · {r.industry}</p>
            <h3>{r.h1}</h3>
            <p>{r.description}</p>
            <span class="more">View solution <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--surface">
    <div class="fx-wrap">
      <div class="fx-cta fx-reveal">
        <p class="fx-eyebrow">Start a project</p>
        <h2>{solution.service} built for {solution.industry}.</h2>
        <p>Tell us your situation. We'll come back with an honest plan, a timeline, and a fixed price.</p>
        <div class="fx-cta-actions">
          <a href="/contact" class="fx-btn fx-btn--light"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
          <a href="/solutions" class="fx-btn fx-btn--outline-light"><span>All solutions</span></a>
        </div>
      </div>
    </div>
  </section>
</SiteClean>
