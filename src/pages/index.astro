---
import SiteClean from "../components/SiteClean.astro";
import { site } from "../data/site";

const title = "Hire DevOps, AI & Full-Stack Engineers | Faynaz Tech";
const description = site.description;
const keywords = [
  "hire devops engineers", "ai automation agency", "full-stack development company",
  "dedicated development team", "offshore software development", "software studio dubai",
];

// FAQ content drives both the visible accordion and the FAQPage schema (kept in sync).
const faqs = [
  {
    key: "faq1",
    q: "How do you price engagements?",
    a: "Most projects are fixed-scope and fixed-price, agreed after a short discovery so there are no surprises. Dedicated engineers run on a simple monthly retainer.",
  },
  {
    key: "faq2",
    q: "How quickly can you start?",
    a: "Typically within two weeks. We stay deliberately small so a senior team is available soon, rather than a queue months out.",
  },
  {
    key: "faq3",
    q: "Do we own the code and IP?",
    a: "Yes, entirely. You own the repository, the infrastructure, and all IP from day one. We build on your accounts, so there is no lock-in.",
  },
  {
    key: "faq4",
    q: "Where is your team based?",
    a: "We are based in Dubai, UAE, and work remotely with clients across the UK, Europe, Australia, Singapore, and the US.",
  },
  {
    key: "faq5",
    q: "What happens after launch?",
    a: "We monitor the release, fix anything that surfaces, and can stay on a support retainer — or hand over clean, documented code.",
  },
];

const faqSchema = {
  "@type": "FAQPage",
  "@id": `${site.url}/#faq`,
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<SiteClean title={title} description={description} keywords={keywords} schema={[faqSchema]}>
  <!-- HERO -->
  <section class="fx-hero fx-section--plain">
    <div class="fx-wrap">
      <div class="fx-hero-grid">
        <div class="fx-hero-copy">
          <p class="fx-eyebrow" data-i18n="hero_eyebrow">Software · DevOps · AI automation studio</p>
          <h1>
            <span data-i18n="hero_h1a">Software, </span><span class="hl" data-i18n="hero_h1b">DevOps &amp; AI automation</span><span data-i18n="hero_h1c"> — shipped and run for you.</span>
          </h1>
          <p class="fx-lead" data-i18n="hero_lead">Hire senior DevOps, AI, and full-stack engineers — as a dedicated team or a managed service. From strategy to a dependable release, with none of the agency overhead.</p>
          <div class="fx-hero-actions">
            <a href="/contact" class="fx-btn fx-btn--primary">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M6.5 3.5 9 4l1 3.5-1.8 1.4a12 12 0 0 0 5.4 5.4L15 16.5 18.5 18l.5 2.5a1.6 1.6 0 0 1-1.7 1.9A16 16 0 0 1 3.6 8.2 1.6 1.6 0 0 1 5.5 6.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span data-i18n="hero_cta1">Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span>
            </a>
            <a href="/#estimate" class="fx-btn fx-btn--ghost"><span data-i18n="hero_cta2">Estimate your project</span></a>
          </div>
          <div class="fx-hero-meta"><span class="dot" aria-hidden="true"></span><span data-i18n="hero_meta">Booking projects for Q3 — typical start within two weeks.</span></div>
        </div>
        <div class="fx-hero-visual fx-reveal">
          <div class="fx-console" role="img" aria-label="Illustration of an automated delivery pipeline: build, test, and deploy.">
            <div class="fx-console-bar"><div class="lights" aria-hidden="true"><span></span><span></span><span></span></div><div class="tag">pipeline · production</div></div>
            <div class="fx-caps">
              <span class="fx-chip">CI/CD</span><span class="fx-chip">Kubernetes</span><span class="fx-chip">Monitoring</span>
            </div>
            <div class="fx-steps">
              <div class="fx-step done"><span class="ck" aria-hidden="true">✓</span><span data-i18n="hp_build">Build</span></div>
              <div class="fx-step done"><span class="ck" aria-hidden="true">✓</span><span data-i18n="hp_test">Automated tests</span></div>
              <div class="fx-step done"><span class="ck" aria-hidden="true">✓</span><span data-i18n="hp_scan">Security scan</span></div>
              <div class="fx-step active"><span class="ck" aria-hidden="true">→</span><span data-i18n="hp_deploy">Deploy</span></div>
            </div>
            <div class="fx-console-note" data-i18n="hp_note">How we ship — automated, tested, and reliable.</div>
          </div>
        </div>
      </div>
      <div class="fx-marquee" aria-hidden="true">
        <div class="fx-marquee-track">
          <span data-i18n="m1">Full-stack development</span><span data-i18n="m2">DevOps &amp; cloud</span><span data-i18n="m3">AI automation</span><span data-i18n="m4">AI agents</span><span data-i18n="m5">Dedicated teams</span><span data-i18n="m6">QA &amp; release</span>
          <span data-i18n="m1">Full-stack development</span><span data-i18n="m2">DevOps &amp; cloud</span><span data-i18n="m3">AI automation</span><span data-i18n="m4">AI agents</span><span data-i18n="m5">Dedicated teams</span><span data-i18n="m6">QA &amp; release</span>
        </div>
      </div>
    </div>
  </section>

  <!-- STACK -->
  <section class="fx-trust">
    <div class="fx-wrap">
      <p class="fx-trust-label" data-i18n="trust_label">The modern stack we build and ship on</p>
      <div class="fx-logos">
        <span>React</span><span>Next.js</span><span>Node.js</span><span>Python</span><span>AWS</span><span>Kubernetes</span><span>Docker</span><span>Terraform</span><span>PostgreSQL</span><span>OpenAI</span>
      </div>
    </div>
  </section>

  <!-- SERVICES (3 pillars) -->
  <section class="fx-section" id="services">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal">
        <p class="fx-eyebrow" data-i18n="svc_eyebrow">Services</p>
        <h2 data-i18n="svc_h2">Three pillars that put engineering to work.</h2>
        <p data-i18n="svc_p">Focused offerings, scoped clearly, priced so you know what you're buying before we start.</p>
      </div>
      <div class="fx-cards">
        <a class="fx-card fx-reveal" href="/services/full-stack-development">
          <div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="M3 12l9 5 9-5M3 16l9 5 9-5"/></svg></div>
          <h3 data-i18n="svc1_h">Full-stack development</h3>
          <p data-i18n="svc1_p">Web apps, SaaS platforms, MVPs, and APIs built to convert and scale.</p>
          <span class="more" data-i18n="svc_more">Learn more <span aria-hidden="true">→</span></span>
        </a>
        <a class="fx-card fx-reveal" href="/services/devops">
          <div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3Z"/><path d="M9 12l2 2 4-4.5"/></svg></div>
          <h3 data-i18n="svc2_h">DevOps &amp; cloud</h3>
          <p data-i18n="svc2_p">CI/CD, Kubernetes, cloud migration, infrastructure as code, and reliability.</p>
          <span class="more" data-i18n="svc_more">Learn more <span aria-hidden="true">→</span></span>
        </a>
        <a class="fx-card fx-reveal" href="/services/ai-automation">
          <div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="6" cy="6" r="2.2"/><circle cx="18" cy="6" r="2.2"/><circle cx="12" cy="18" r="2.2"/><path d="M7.5 7.6 11 15.5M16.5 7.6 13 15.5M8 6h8"/></svg></div>
          <h3 data-i18n="svc3_h">AI automation</h3>
          <p data-i18n="svc3_p">Workflow automation, AI agents, and LLM integration that cut manual work.</p>
          <span class="more" data-i18n="svc_more">Learn more <span aria-hidden="true">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- TWO MODELS -->
  <section class="fx-section fx-section--surface" id="models">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal">
        <p class="fx-eyebrow" data-i18n="mdl_eyebrow">Two ways to work with us</p>
        <h2 data-i18n="mdl_h2">Hire a team, or hand us the outcome.</h2>
      </div>
      <div class="fx-models fx-reveal">
        <div class="fx-model">
          <span class="tag" data-i18n="mdl1_tag">Dedicated team</span>
          <h3 data-i18n="mdl1_h">Hire senior engineers</h3>
          <p data-i18n="mdl1_p">DevOps, AI, and full-stack engineers who plug into your team on a monthly retainer.</p>
          <ul>
            <li><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="m4 10 4 4 8-9"/></svg><span data-i18n="mdl1_l1">Full control, daily collaboration</span></li>
            <li><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="m4 10 4 4 8-9"/></svg><span data-i18n="mdl1_l2">Senior engineers only</span></li>
            <li><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="m4 10 4 4 8-9"/></svg><span data-i18n="mdl1_l3">Scale up or down flexibly</span></li>
          </ul>
          <a href="/hire" class="fx-btn fx-btn--ghost"><span data-i18n="mdl1_cta">Hire an engineer</span></a>
        </div>
        <div class="fx-model alt">
          <span class="tag" data-i18n="mdl2_tag">Managed service</span>
          <h3 data-i18n="mdl2_h">Hand us the outcome</h3>
          <p data-i18n="mdl2_p">We scope, build, and deliver a defined outcome at a fixed price.</p>
          <ul>
            <li><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="m4 10 4 4 8-9"/></svg><span data-i18n="mdl2_l1">Fixed scope and price</span></li>
            <li><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="m4 10 4 4 8-9"/></svg><span data-i18n="mdl2_l2">QA and release built in</span></li>
            <li><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="m4 10 4 4 8-9"/></svg><span data-i18n="mdl2_l3">You own all the code</span></li>
          </ul>
          <a href="/contact" class="fx-btn fx-btn--light"><span data-i18n="mdl2_cta">Let's have a call</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ESTIMATOR -->
  <section class="fx-section" id="estimate">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal">
        <p class="fx-eyebrow" data-i18n="est_eyebrow">Project estimator</p>
        <h2 data-i18n="est_h2">Get a ballpark in under a minute.</h2>
        <p data-i18n="est_p">Pick what you're building. The estimate updates live — no form, no waiting for a sales call.</p>
      </div>
      <div class="fx-est-grid">
        <div class="fx-est-panel fx-reveal">
          <div class="fx-est-head">
            <div class="fx-est-progress"><i id="fx-est-bar"></i></div>
            <div class="fx-est-count"><span id="fx-est-cur">1</span> / <span id="fx-est-total">7</span></div>
          </div>
          <div class="fx-est-steps" id="fx-est-steps">
          <div class="fx-est-step">
            <div class="fx-est-q"><span class="qn">01</span><span data-i18n="est_q1">What are you building?</span></div>
            <div class="fx-opts" data-group="type" data-mode="single">
              <button class="fx-opt" type="button" aria-pressed="true" data-cost="10000"><span data-i18n="t_web">Website</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="22000"><span data-i18n="t_app">Web app</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="28000"><span data-i18n="t_mobile">Mobile app</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="40000"><span data-i18n="t_saas">SaaS platform</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="18000"><span data-i18n="t_ai">AI / automation</span></button>
            </div>
          </div>
          <div class="fx-est-step">
            <div class="fx-est-q"><span class="qn">02</span><span data-i18n="est_q2">Project scale</span></div>
            <div class="fx-opts" data-group="scale" data-mode="single">
              <button class="fx-opt" type="button" aria-pressed="false" data-mult="0.8"><span data-i18n="sc_mvp">MVP / prototype</span></button>
              <button class="fx-opt" type="button" aria-pressed="true" data-mult="1"><span data-i18n="sc_growth">Growth stage</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-mult="1.45"><span data-i18n="sc_ent">Enterprise-grade</span></button>
            </div>
          </div>
          <div class="fx-est-step">
            <div class="fx-est-q"><span class="qn">03</span><span data-i18n="est_q3">Which platforms?</span></div>
            <div class="fx-opts" data-group="platform" data-mode="multi">
              <button class="fx-opt" type="button" aria-pressed="true" data-cost="0"><span class="tick">✓</span><span data-i18n="p_web">Web</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="9000"><span class="tick">✓</span><span data-i18n="p_ios">iOS</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="9000"><span class="tick">✓</span><span data-i18n="p_android">Android</span></button>
            </div>
          </div>
          <div class="fx-est-step">
            <div class="fx-est-q"><span class="qn">04</span><span data-i18n="est_q4">Key features</span></div>
            <div class="fx-opts" data-group="features" data-mode="multi">
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="4000"><span class="tick">✓</span><span data-i18n="f_auth">User accounts</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="7000"><span class="tick">✓</span><span data-i18n="f_pay">Payments</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="6000"><span class="tick">✓</span><span data-i18n="f_dash">Dashboard / admin</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="6500"><span class="tick">✓</span><span data-i18n="f_api">Integrations / API</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="9000"><span class="tick">✓</span><span data-i18n="f_ai">AI features</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="4500"><span class="tick">✓</span><span data-i18n="f_cms">CMS / content</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="6000"><span class="tick">✓</span><span data-i18n="f_rt">Real-time / chat</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="3000"><span class="tick">✓</span><span data-i18n="f_notif">Notifications</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="4000"><span class="tick">✓</span><span data-i18n="f_analytics">Analytics</span></button>
            </div>
          </div>
          <div class="fx-est-step">
            <div class="fx-est-q"><span class="qn">05</span><span data-i18n="est_q5">Enterprise add-ons</span></div>
            <div class="fx-opts" data-group="addons" data-mode="multi">
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="8000"><span class="tick">✓</span><span data-i18n="a_design">New UI/UX design</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="10000"><span class="tick">✓</span><span data-i18n="a_compliance">Security &amp; compliance (SOC 2 / HIPAA)</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="9000"><span class="tick">✓</span><span data-i18n="a_multitenant">Multi-tenant architecture</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-cost="7000"><span class="tick">✓</span><span data-i18n="a_devops">Cloud &amp; DevOps setup</span></button>
            </div>
          </div>
          <div class="fx-est-step">
            <div class="fx-est-q"><span class="qn">06</span><span data-i18n="est_q6">Timeline</span></div>
            <div class="fx-opts" data-group="timeline" data-mode="single">
              <button class="fx-opt" type="button" aria-pressed="true" data-mult="1"><span data-i18n="tl_std">Standard</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-mult="1.25"><span data-i18n="tl_fast">Fast-track</span></button>
            </div>
          </div>
          <div class="fx-est-step">
            <div class="fx-est-q"><span class="qn">07</span><span data-i18n="est_q7">Ongoing support?</span></div>
            <div class="fx-opts" data-group="support" data-mode="single">
              <button class="fx-opt" type="button" aria-pressed="true" data-support="0"><span data-i18n="su_no">Not now</span></button>
              <button class="fx-opt" type="button" aria-pressed="false" data-support="1"><span data-i18n="su_yes">Care plan</span></button>
            </div>
          </div>
          </div>
          <div class="fx-est-nav">
            <button class="fx-btn fx-btn--ghost" id="fx-est-back" type="button" disabled><span aria-hidden="true">←</span> <span data-i18n="est_back_btn">Back</span></button>
            <button class="fx-btn fx-btn--primary" id="fx-est-next" type="button"><span class="lbl" data-i18n="est_next_btn">Next</span> <span aria-hidden="true">→</span></button>
          </div>
        </div>
        <aside class="fx-readout" aria-live="polite">
          <div class="rl" data-i18n="est_rl">Estimated investment</div>
          <div class="price"><span class="cur">$</span><span id="fx-est-min">0</span> – <span class="cur">$</span><span id="fx-est-max">0</span></div>
          <div class="rrow"><span data-i18n="est_hours">Engineering hours</span><b id="fx-est-hours">0</b></div>
          <div class="rrow"><span data-i18n="est_weeks">Delivery window</span><b><span id="fx-est-weeks">0</span> <span data-i18n="est_wk">weeks</span></b></div>
          <div class="rrow"><span data-i18n="est_team">Team size</span><b id="fx-est-team">0</b></div>
          <div class="rrow" id="fx-est-care-row" style="display:none"><span data-i18n="est_care">Ongoing care</span><b><span class="cur">$</span><span id="fx-est-care">0</span> <span data-i18n="est_mo">/mo</span></b></div>
          <a href="/contact" class="fx-btn fx-btn--primary"><span data-i18n="est_book">Let's have a call to refine it</span></a>
          <div class="note" data-i18n="est_note">Indicative range. Book a call for a fixed, itemized quote.</div>
        </aside>
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="fx-section fx-section--surface" id="why">
    <div class="fx-wrap fx-why-grid">
      <div class="fx-head fx-reveal" style="margin-bottom:0">
        <p class="fx-eyebrow" data-i18n="why_eyebrow">Why teams choose us</p>
        <h2 data-i18n="why_h2">Senior work, without the agency friction.</h2>
        <p data-i18n="why_p">You get the people doing the thinking in the same room as the people writing the code.</p>
      </div>
      <div class="fx-why-list fx-reveal">
        <div class="fx-why-item"><span class="k"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m13 3-8 10h6l-1 8 8-10h-6l1-8Z"/></svg></span><div><h3 data-i18n="why1_h">Speed you can plan around</h3><p data-i18n="why1_p">Small senior teams and tight scope mean a first release in weeks, with dates we hold to.</p></div></div>
        <div class="fx-why-item"><span class="k"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 5h16v11H9l-4 3V5Z"/></svg></span><div><h3 data-i18n="why2_h">Direct communication</h3><p data-i18n="why2_p">You talk to the engineers and lead — no account layer translating requirements twice.</p></div></div>
        <div class="fx-why-item"><span class="k"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m8 8-4 4 4 4M16 8l4 4-4 4M13 5l-2 14"/></svg></span><div><h3 data-i18n="why3_h">Real technical depth</h3><p data-i18n="why3_p">Architecture and performance decisions made by people who've shipped them before.</p></div></div>
        <div class="fx-why-item"><span class="k"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21c-4-2-7-5.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 4.5-3 8-7 10Z"/></svg></span><div><h3 data-i18n="why4_h">Built around the business</h3><p data-i18n="why4_p">We start from the outcome you're measured on, then choose the tech.</p></div></div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="fx-section" id="process">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal"><p class="fx-eyebrow" data-i18n="proc_eyebrow">How we work</p><h2 data-i18n="proc_h2">A four-step engagement, start to scale.</h2></div>
      <div class="fx-process fx-reveal">
        <div class="fx-pstep"><div class="num" data-i18n="proc_s1n">Step 01</div><h3 data-i18n="proc1_h">Discover</h3><p data-i18n="proc1_p">We map the goal, constraints, and success metric before any code.</p></div>
        <div class="fx-pstep"><div class="num" data-i18n="proc_s2n">Step 02</div><h3 data-i18n="proc2_h">Design</h3><p data-i18n="proc2_p">Flows, interfaces, and architecture — agreed and scoped to a fixed plan.</p></div>
        <div class="fx-pstep"><div class="num" data-i18n="proc_s3n">Step 03</div><h3 data-i18n="proc3_h">Build</h3><p data-i18n="proc3_p">Senior engineers ship in short cycles, with QA baked into every release.</p></div>
        <div class="fx-pstep"><div class="num" data-i18n="proc_s4n">Step 04</div><h3 data-i18n="proc4_h">Launch &amp; scale</h3><p data-i18n="proc4_p">We go live, watch the numbers, and keep the system ready for what's next.</p></div>
      </div>
    </div>
  </section>

  <!-- OUTCOMES -->
  <section class="fx-section fx-section--surface" id="outcomes">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal"><p class="fx-eyebrow" data-i18n="out_eyebrow">What we deliver</p><h2 data-i18n="out_h2">The outcomes we engineer for.</h2></div>
      <div class="fx-cards">
        <div class="fx-card fx-reveal"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m13 3-8 10h6l-1 8 8-10h-6l1-8Z"/></svg></div><h3 data-i18n="out1_h">Ship faster, break less</h3><p data-i18n="out1_p">Automated CI/CD, cloud, and monitoring so your team releases often and recovers quickly when something goes wrong.</p></div>
        <div class="fx-card fx-reveal"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="6" cy="6" r="2.2"/><circle cx="18" cy="6" r="2.2"/><circle cx="12" cy="18" r="2.2"/><path d="M7.5 7.6 11 15.5M16.5 7.6 13 15.5M8 6h8"/></svg></div><h3 data-i18n="out2_h">Cut the manual work</h3><p data-i18n="out2_p">Workflow automation and practical AI that remove repetitive tasks and free your team for higher-value work.</p></div>
        <div class="fx-card fx-reveal"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="M3 12l9 5 9-5M3 16l9 5 9-5"/></svg></div><h3 data-i18n="out3_h">Build products that scale</h3><p data-i18n="out3_p">Web apps and platforms architected to stay fast and maintainable as your users and features grow.</p></div>
      </div>
    </div>
  </section>

  <!-- COMMITMENTS -->
  <section class="fx-section" id="commitments">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal"><p class="fx-eyebrow" data-i18n="com_eyebrow">Our commitments</p><h2 data-i18n="com_h2">What you can count on — in writing.</h2></div>
      <div class="fx-cards">
        <div class="fx-card fx-reveal"><h3 data-i18n="com1_h">Senior engineers only</h3><p data-i18n="com1_p">The people on your first call are the ones who deliver. No junior bench, no bait-and-switch.</p></div>
        <div class="fx-card fx-reveal"><h3 data-i18n="com2_h">Fixed scope and price</h3><p data-i18n="com2_p">Agreed after a short discovery, so there are no surprise invoices mid-project.</p></div>
        <div class="fx-card fx-reveal"><h3 data-i18n="com3_h">You own everything</h3><p data-i18n="com3_p">Code, cloud accounts, and IP are yours from day one. We build on your accounts — no lock-in.</p></div>
      </div>
    </div>
  </section>

  <!-- CREDIBILITY (real, verifiable) -->
  <section class="fx-section fx-section--surface" style="padding-block:clamp(30px,4vw,48px)">
    <div class="fx-wrap">
      <div class="fx-verify fx-reveal">
        <span class="item"><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg><span data-i18n="cred_founded">Founded 2021 · Dubai, UAE</span></span>
        <span class="sep" aria-hidden="true"></span>
        <a class="item" href={site.social.clutch} target="_blank" rel="noopener noreferrer"><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg><span data-i18n="cred_clutch">Find us on Clutch</span> <span aria-hidden="true">↗</span></a>
        <span class="sep" aria-hidden="true"></span>
        <a class="item" href={site.social.linkedin} target="_blank" rel="noopener noreferrer"><svg class="ic" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1-.02-5ZM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.8-2.05 3.7-2.05 4 0 4.75 2.6 4.75 6V21h-4v-5.3c0-1.3 0-2.9-1.8-2.9s-2 1.4-2 2.8V21h-4z"/></svg><span data-i18n="cred_linkedin">Connect on LinkedIn</span> <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="fx-section" id="faq">
    <div class="fx-wrap fx-faq-grid">
      <div class="fx-head fx-reveal" style="margin-bottom:0"><p class="fx-eyebrow" data-i18n="faq_eyebrow">FAQ</p><h2 data-i18n="faq_h2">The questions decision-makers ask.</h2></div>
      <div class="fx-reveal">
        {faqs.map((f, i) => (
          <details class="fx-faq" open={i === 0}>
            <summary><span data-i18n={`${f.key}_q`}>{f.q}</span><span class="plus" aria-hidden="true"></span></summary>
            <div class="ans" data-i18n={`${f.key}_a`}>{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="fx-section fx-section--surface" id="contact-cta">
    <div class="fx-wrap">
      <div class="fx-cta fx-reveal">
        <p class="fx-eyebrow" data-i18n="cta_eyebrow">Start a project</p>
        <h2 data-i18n="cta_h2">Let's scope your next release.</h2>
        <p data-i18n="cta_p">Tell us what you're trying to move. We'll come back with an honest plan, a timeline, and a fixed price.</p>
        <div class="fx-cta-actions">
          <a href="/contact" class="fx-btn fx-btn--light">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M6.5 3.5 9 4l1 3.5-1.8 1.4a12 12 0 0 0 5.4 5.4L15 16.5 18.5 18l.5 2.5a1.6 1.6 0 0 1-1.7 1.9A16 16 0 0 1 3.6 8.2 1.6 1.6 0 0 1 5.5 6.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span data-i18n="cta_b1">Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span>
          </a>
          <a href="/#estimate" class="fx-btn fx-btn--outline-light"><span data-i18n="cta_b2">Use the estimator</span></a>
        </div>
      </div>
    </div>
  </section>
</SiteClean>
