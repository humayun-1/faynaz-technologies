---
import SiteClean from "../../components/SiteClean.astro";
import { site } from "../../data/site";
import { caseStudies } from "../../data/casestudies";

const title = "Our Work, Case Studies | Faynaz Technologies";
const description =
  "Case studies from Faynaz Technologies, how we build web platforms, DevOps, and AI automation for startups and businesses, measured by outcomes.";

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site.url}/` },
    { "@type": "ListItem", position: 2, name: "Work", item: `${site.url}/work` },
  ],
};
const collection = {
  "@type": "CollectionPage",
  "@id": `${site.url}/work#webpage`,
  url: `${site.url}/work`,
  name: title,
  isPartOf: { "@id": `${site.url}/#website` },
  hasPart: caseStudies.map((c) => ({ "@type": "CreativeWork", name: c.title, url: `${site.url}/work/${c.slug}` })),
};
---

<SiteClean title={title} description={description} canonical="/work" schema={[breadcrumb, collection]}>
  <section class="fx-subhero">
    <div class="fx-wrap">
      <nav class="fx-crumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>Work</span></nav>
      <p class="fx-eyebrow">Our work</p>
      <h1>Measured by outcomes, not screenshots.</h1>
      <p class="fx-lead">A look at the kind of work we do, web platforms, DevOps, and AI automation, and the results we build toward for startups and growing teams.</p>
      <div class="fx-subhero-actions">
        <a href="/contact" class="fx-btn fx-btn--primary"><span>Start a project</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
        <a href="/#estimate" class="fx-btn fx-btn--ghost"><span>Estimate your project</span></a>
      </div>
    </div>
  </section>

  <section class="fx-section">
    <div class="fx-wrap">
      <div class="fx-work-grid fx-reveal">
        {caseStudies.map((c) => (
          <a class="fx-work" href={`/work/${c.slug}`}>
            <div class="sector">{c.sector}{c.illustrative && <span class="fx-illus" style="margin-inline-start:8px">Illustrative</span>}</div>
            <div class="stat">{c.stat}</div>
            <h3>{c.title}</h3>
            <p>{c.summary}</p>
            <div class="foot">{c.engagement} · <span style="color:var(--accent);font-weight:600">Read →</span></div>
          </a>
        ))}
      </div>
      <div class="fx-note-band fx-reveal" style="margin-top:20px">
        These are <strong>illustrative engagements</strong>, representative of the work and outcomes we deliver. We replace them with named client stories as clients approve them.
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--surface">
    <div class="fx-wrap">
      <div class="fx-cta fx-reveal">
        <p class="fx-eyebrow">Your project next</p>
        <h2>Let's build something worth a case study.</h2>
        <p>Tell us what you're building. We'll come back with an honest plan, a timeline, and a fixed price.</p>
        <div class="fx-cta-actions">
          <a href="/contact" class="fx-btn fx-btn--light"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
          <a href="/startups" class="fx-btn fx-btn--outline-light"><span>For startups</span></a>
        </div>
      </div>
    </div>
  </section>
</SiteClean>
