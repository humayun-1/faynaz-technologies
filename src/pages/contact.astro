---
import SiteClean from "../components/SiteClean.astro";
import { site } from "../data/site";

const title = "Contact Faynaz Technologies — Book a Discovery Call";
const description =
  "Talk to Faynaz Technologies about your software, DevOps, or AI automation project. Book a discovery call, or reach us by email, phone, or WhatsApp.";

const tel = site.phoneUae.replace(/\s/g, "");
const wa = "https://wa.me/" + site.phoneUae.replace(/[^0-9]/g, "");
const FORM_ENDPOINT = site.formEndpoint;

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site.url}/` },
    { "@type": "ListItem", position: 2, name: "Contact", item: `${site.url}/contact` },
  ],
};
const contactPage = {
  "@type": "ContactPage",
  "@id": `${site.url}/contact#webpage`,
  url: `${site.url}/contact`,
  name: title,
  isPartOf: { "@id": `${site.url}/#website` },
  about: { "@id": `${site.url}/#organization` },
};
---

<SiteClean title={title} description={description} canonical="/contact" schema={[breadcrumb, contactPage]}>
  <section class="fx-subhero">
    <div class="fx-wrap">
      <nav class="fx-crumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>Contact</span></nav>
      <p class="fx-eyebrow">Contact</p>
      <h1>Let's talk about your project.</h1>
      <p class="fx-lead">Tell us what you're building or the problem you're solving. We'll reply within one business day with honest next steps — no pushy sales.</p>
    </div>
  </section>

  <section class="fx-section fx-section--plain" style="padding-top:clamp(36px,5vw,56px)">
    <div class="fx-wrap fx-contact-grid">
      <div>
        <form class="fx-form" action={FORM_ENDPOINT} method="POST">
          <div class="fx-field">
            <label for="cf-name">Name</label>
            <input class="fx-input" id="cf-name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="fx-field">
            <label for="cf-email">Work email</label>
            <input class="fx-input" id="cf-email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="fx-field">
            <label for="cf-company">Company (optional)</label>
            <input class="fx-input" id="cf-company" name="company" type="text" autocomplete="organization" />
          </div>
          <div class="fx-field">
            <label for="cf-message">What do you need?</label>
            <textarea class="fx-textarea" id="cf-message" name="message" required placeholder="A few lines about your project, timeline, and the outcome you're after."></textarea>
          </div>
          <button class="fx-btn fx-btn--primary" type="submit"><span>Send message</span> <span class="fx-arrow" aria-hidden="true">→</span></button>
        </form>
      </div>

      <aside class="fx-contact-side">
        <a class="fx-contact-card" href={site.booking} target="_blank" rel="noopener noreferrer">
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18M8 2.5v4M16 2.5v4"/></svg></span>
          <span><span class="t">Prefer to talk?</span><span class="v">Book a discovery call</span></span>
        </a>
        <a class="fx-contact-card" href={`mailto:${site.email}`}>
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></span>
          <span><span class="t">Email</span><span class="v">{site.email}</span></span>
        </a>
        <a class="fx-contact-card" href={`tel:${tel}`}>
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M6.5 3.5 9 4l1 3.5-1.8 1.4a12 12 0 0 0 5.4 5.4L15 16.5 18.5 18l.5 2.5a1.6 1.6 0 0 1-1.7 1.9A16 16 0 0 1 3.6 8.2 1.6 1.6 0 0 1 5.5 6.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <span><span class="t">Phone</span><span class="v">{site.phoneUae}</span></span>
        </a>
        <a class="fx-contact-card" href={wa} target="_blank" rel="noopener noreferrer">
          <span class="ic"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.5 14.1c-.2.6-1.2 1.2-1.7 1.2-.4 0-1 .1-3.2-.9-2.7-1.2-4.4-4-4.5-4.2-.1-.2-1.1-1.4-1.1-2.7s.7-1.9.9-2.1c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.4 2.6 1.6.2.1.4.1.6-.1l.7-.8c.2-.2.3-.2.6-.1l1.9.9c.3.2.5.2.6.4.1.1.1.7-.1 1.3Z"/></svg></span>
          <span><span class="t">WhatsApp</span><span class="v">Message us</span></span>
        </a>
        <div class="fx-contact-card">
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
          <span><span class="t">Based in</span><span class="v">Jumeirah Lake Towers, Dubai</span></span>
        </div>
      </aside>
    </div>
  </section>

  <section class="fx-section fx-section--surface" id="book">
    <div class="fx-wrap">
      <div class="fx-cta fx-reveal">
        <p class="fx-eyebrow">Book a call</p>
        <h2>Grab a 30-minute discovery call.</h2>
        <p>We'll listen, ask the right questions, and tell you honestly whether and how we can help.</p>
        <div class="fx-cta-actions">
          <a href={site.booking} target="_blank" rel="noopener noreferrer" class="fx-btn fx-btn--light"><span>Book a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
          <a href="/#estimate" class="fx-btn fx-btn--outline-light"><span>Use the estimator</span></a>
        </div>
      </div>
    </div>
  </section>
</SiteClean>
