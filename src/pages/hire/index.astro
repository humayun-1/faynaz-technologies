---
import SiteClean from "../../components/SiteClean.astro";
import { site } from "../../data/site";
import { roles } from "../../data/roles";

const title = "Hire Developers & Engineers — Dedicated Team | Faynaz Technologies";
const description =
  "Hire senior developers and engineers from a Dubai studio — DevOps, AI/ML, cloud, React, Node.js, Python, and full-stack. Dedicated team or managed service, with real timezone overlap.";

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site.url}/` },
    { "@type": "ListItem", position: 2, name: "Hire engineers", item: `${site.url}/hire` },
  ],
};
const collection = {
  "@type": "CollectionPage",
  "@id": `${site.url}/hire#webpage`,
  url: `${site.url}/hire`,
  name: title,
  isPartOf: { "@id": `${site.url}/#website` },
  hasPart: roles.map((r) => ({ "@type": "Service", name: r.h1, url: `${site.url}/hire/${r.slug}` })),
};
---

<SiteClean title={title} description={description} canonical="/hire" schema={[breadcrumb, collection]}>
  <section class="fx-subhero">
    <div class="fx-wrap">
      <nav class="fx-crumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>Hire engineers</span></nav>
      <p class="fx-eyebrow">Dedicated team</p>
      <h1>Hire senior developers and engineers.</h1>
      <p class="fx-lead">Add vetted, senior engineers to your team on a monthly retainer — or hand us a fixed-scope build. Real timezone overlap from Dubai, and you own all the code.</p>
      <div class="fx-subhero-actions">
        <a href="/contact" class="fx-btn fx-btn--primary"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
        <a href="/#estimate" class="fx-btn fx-btn--ghost"><span>Estimate your project</span></a>
      </div>
    </div>
  </section>

  <section class="fx-section">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal">
        <p class="fx-eyebrow">Roles</p>
        <h2>Pick the engineers you need.</h2>
      </div>
      <div class="fx-cards fx-reveal">
        {roles.map((r) => (
          <a class="fx-card" href={`/hire/${r.slug}`}>
            <p class="fx-eyebrow" style="margin-bottom:12px">{r.category}</p>
            <h3>{r.h1}</h3>
            <p>{r.description}</p>
            <span class="more">View role <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--surface">
    <div class="fx-wrap">
      <div class="fx-cta fx-reveal">
        <p class="fx-eyebrow">Start hiring</p>
        <h2>Tell us what you need on your team.</h2>
        <p>We'll match you with the right senior engineer, a start date, and a simple monthly rate.</p>
        <div class="fx-cta-actions">
          <a href="/contact" class="fx-btn fx-btn--light"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
          <a href="/service" class="fx-btn fx-btn--outline-light"><span>See services</span></a>
        </div>
      </div>
    </div>
  </section>
</SiteClean>
