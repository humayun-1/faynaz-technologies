---
import SiteClean from "../../components/SiteClean.astro";
import { site } from "../../data/site";
import { roles, relatedRoles } from "../../data/roles";

export function getStaticPaths() {
  return roles.map((r) => ({ params: { role: r.slug }, props: { role: r } }));
}

const { role } = Astro.props;
const path = `/hire/${role.slug}`;
const title = `${role.h1} | Faynaz Technologies`;
const related = relatedRoles(role.slug);

// One shared, honest FAQ appended to each role's specific ones.
const faqs = [
  ...role.faqs,
  {
    q: `Where are your ${role.role} based?`,
    a: `Our ${role.role} are based in Dubai, UAE, and work remotely with clients across the UK, Europe, Australia, Singapore, and the US. Dubai's timezone overlaps European and UK mornings and Asian afternoons, giving several hours of daily real-time overlap.`,
  },
];

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site.url}/` },
    { "@type": "ListItem", position: 2, name: "Hire engineers", item: `${site.url}/hire` },
    { "@type": "ListItem", position: 3, name: role.h1, item: `${site.url}${path}` },
  ],
};
const service = {
  "@type": "Service",
  name: role.h1,
  serviceType: `${role.role} — staff augmentation`,
  description: role.description,
  provider: { "@id": `${site.url}/#organization` },
  areaServed: site.areaServed,
};
const faqSchema = {
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
---

<SiteClean title={title} description={role.description} canonical={path} schema={[breadcrumb, service, faqSchema]}>
  <section class="fx-subhero">
    <div class="fx-wrap">
      <nav class="fx-crumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><a href="/hire">Hire engineers</a><span class="sep">/</span><span>{role.role}</span></nav>
      <p class="fx-eyebrow">Dedicated team · {role.category}</p>
      <h1>{role.h1}</h1>
      <p class="fx-lead">{role.intro}</p>
      <div class="fx-subhero-actions">
        <a href="/contact" class="fx-btn fx-btn--primary"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
        <a href="/#estimate" class="fx-btn fx-btn--ghost"><span>Estimate your project</span></a>
      </div>
    </div>
  </section>

  <section class="fx-section fx-section--plain" style="padding-top:clamp(40px,5vw,64px)">
    <div class="fx-wrap fx-guide">
      <div class="fx-prose">
        <h2>What our {role.role} do</h2>
        <div class="fx-chips">
          {role.skills.map((s) => <span class="fx-chip">{s}</span>)}
        </div>
        <h2 style="margin-top:34px">What they build</h2>
        <ul>
          {role.builds.map((b) => <li>{b}</li>)}
        </ul>

        <h2>Why hire {role.role} through Faynaz</h2>
        <ul>
          <li><strong>Senior only.</strong> You get experienced engineers, not a junior bench — the people on the first call are the ones who deliver.</li>
          <li><strong>Real timezone overlap.</strong> From Dubai we overlap UK and European mornings and Asian afternoons, so collaboration is same-day, not next-day.</li>
          <li><strong>You own everything.</strong> Code, cloud accounts, and IP are yours from day one — no lock-in.</li>
          <li><strong>Flexible engagement.</strong> Scale the team up or down monthly, or switch to a fixed-scope managed build.</li>
        </ul>
      </div>

      <div class="fx-inline-cta">
        <p>Ready to add {role.role} to your team?<span>Book a call, or get a ballpark from the estimator first.</span></p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <a href="/#estimate" class="fx-btn fx-btn--ghost"><span>Estimate</span></a>
          <a href="/contact" class="fx-btn fx-btn--primary"><span>Let's have a call</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- two models -->
  <section class="fx-section fx-section--surface" id="models">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal">
        <p class="fx-eyebrow">Two ways to work with us</p>
        <h2>Hire a team, or hand us the outcome.</h2>
      </div>
      <div class="fx-models fx-reveal">
        <div class="fx-model">
          <span class="tag">Dedicated team</span>
          <h3>Hire {role.role}</h3>
          <p>Senior {role.role} who join your team on a monthly retainer and work your way.</p>
          <a href="/contact" class="fx-btn fx-btn--ghost"><span>Let's have a call</span></a>
        </div>
        <div class="fx-model alt">
          <span class="tag">Managed service</span>
          <h3>Hand us the outcome</h3>
          <p>We scope, build, and deliver a defined outcome at a fixed price. You own all the code.</p>
          <a href="/service" class="fx-btn fx-btn--light"><span>See services</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="fx-section" id="faq">
    <div class="fx-wrap fx-faq-grid">
      <div class="fx-head fx-reveal" style="margin-bottom:0"><p class="fx-eyebrow">FAQ</p><h2>Hiring {role.role}, answered.</h2></div>
      <div class="fx-reveal">
        {faqs.map((f, i) => (
          <details class="fx-faq" open={i === 0}>
            <summary><span>{f.q}</span><span class="plus" aria-hidden="true"></span></summary>
            <div class="ans">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- related roles (internal linking) -->
  <section class="fx-section fx-section--surface" aria-label="Other roles">
    <div class="fx-wrap">
      <div class="fx-head fx-reveal" style="margin-bottom:32px"><p class="fx-eyebrow">Also available</p><h2 style="font-size:clamp(1.5rem,3vw,2rem)">Hire other engineers</h2></div>
      <div class="fx-cards fx-reveal">
        {related.map((r) => (
          <a class="fx-card" href={`/hire/${r.slug}`}>
            <p class="fx-eyebrow" style="margin-bottom:12px">{r.category}</p>
            <h3>{r.h1}</h3>
            <p>{r.description}</p>
            <span class="more">View role <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="fx-section">
    <div class="fx-wrap">
      <div class="fx-cta fx-reveal">
        <p class="fx-eyebrow">Start hiring</p>
        <h2>Add senior {role.role} to your team.</h2>
        <p>Tell us what you need. We'll come back with the right engineer, a start date, and a simple monthly rate.</p>
        <div class="fx-cta-actions">
          <a href="/contact" class="fx-btn fx-btn--light"><span>Let's have a call</span> <span class="fx-arrow" aria-hidden="true">→</span></a>
          <a href="/hire" class="fx-btn fx-btn--outline-light"><span>All roles</span></a>
        </div>
      </div>
    </div>
  </section>
</SiteClean>
