---
import { site } from "../../data/site";
const year = new Date().getFullYear();
---
<footer class="fx-footer">
  <div class="fx-wrap">
    <div class="fx-foot-top">
      <div class="fx-foot-brand">
        <a class="fx-brand" href="/">
          <img class="fx-logo" src={site.logo} width="34" height="34" alt={`${site.name} logo`} />
          <span class="wm">Faynaz<small>Technologies</small></span>
        </a>
        <p data-i18n="foot_about">A Dubai-based software studio building full-stack development, DevOps, and AI automation for teams that need it done right.</p>
        <div class="fx-foot-contact">
          <span data-i18n="foot_addr">Jumeirah Lake Towers — Dubai, UAE</span>
          <span><b data-i18n="foot_email_l">Email:</b> <a href={`mailto:${site.email}`}>{site.email}</a></span>
          <span><b data-i18n="foot_phone_l">Phone:</b> <a href={`tel:${site.phoneUae.replace(/\s/g, "")}`}>{site.phoneUae}</a></span>
        </div>
      </div>
      <div class="fx-foot-col">
        <h4 data-i18n="foot_company">Company</h4>
        <a href="/about" data-i18n="fl_about">About</a>
        <a href="/#models" data-i18n="fl_models">How we work</a>
        <a href="/portfolio" data-i18n="fl_work">Work</a>
        <a href="/#faq" data-i18n="fl_faq">FAQ</a>
        <a href="/contact" data-i18n="fl_contact">Contact</a>
      </div>
      <div class="fx-foot-col">
        <h4 data-i18n="foot_services">Services</h4>
        <a href="/service" data-i18n="fs_full">Full-stack development</a>
        <a href="/service" data-i18n="fs_devops">DevOps &amp; cloud</a>
        <a href="/service" data-i18n="fs_ai">AI automation</a>
        <a href="/hire" data-i18n="fs_hire">Hire engineers</a>
        <a href="/solutions" data-i18n="fs_solutions">Solutions by industry</a>
      </div>
      <div class="fx-foot-col">
        <h4 data-i18n="foot_legal">Legal &amp; resources</h4>
        <a href="#" data-i18n="fr_terms">Terms of service</a>
        <a href="#" data-i18n="fr_privacy">Privacy policy</a>
        <a href="/#estimate" data-i18n="fr_est">Project estimator</a>
      </div>
      <div class="fx-foot-col">
        <h4 data-i18n="foot_recognition">Recognition</h4>
        <div class="fx-badges">
          <span class="fx-badge">Clutch</span><span class="fx-badge">Upwork</span><span class="fx-badge">GoodFirms</span><span class="fx-badge">ISO 27001</span>
        </div>
      </div>
    </div>
    <div class="fx-foot-bottom">
      <span data-i18n="foot_copy">© {year} Faynaz Technologies. All rights reserved.</span>
      <div class="fx-foot-social" aria-label="Social links">
        <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1-.02-5ZM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.8-2.05 3.7-2.05 4 0 4.75 2.6 4.75 6V21h-4v-5.3c0-1.3 0-2.9-1.8-2.9s-2 1.4-2 2.8V21h-4z"/></svg></a>
        <a href={site.social.clutch} target="_blank" rel="noopener noreferrer" aria-label="Clutch" title="Clutch"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m9 12 2 2 4-4"/></svg></a>
      </div>
    </div>
  </div>
</footer>
