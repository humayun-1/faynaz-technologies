---
import { site } from "../../data/site";
---
<header class="fx-header" id="fx-header">
  <div class="fx-wrap fx-nav">
    <a class="fx-brand" href="/" aria-label={`${site.name} home`}>
      <img class="fx-logo" src={site.logo} width="34" height="34" alt={`${site.name} logo`} />
      <span class="wm">Faynaz<small>Technologies</small></span>
    </a>
    <nav class="fx-nav-links" aria-label="Primary">
      <a href="/service" data-i18n="nav_services">Services</a>
      <a href="/hire" data-i18n="nav_hire">Hire engineers</a>
      <a href="/solutions" data-i18n="nav_solutions">Solutions</a>
      <a href="/insights" data-i18n="nav_insights">Insights</a>
      <a href="/about" data-i18n="nav_about">About</a>
    </nav>
    <div class="fx-nav-right">
      <button class="fx-lang" id="fx-lang" type="button" aria-label="Switch language">
        <svg class="globe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/></svg>
        <span id="fx-lang-label">العربية</span>
      </button>
      <a href="/contact" class="fx-btn fx-btn--primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M6.5 3.5 9 4l1 3.5-1.8 1.4a12 12 0 0 0 5.4 5.4L15 16.5 18.5 18l.5 2.5a1.6 1.6 0 0 1-1.7 1.9A16 16 0 0 1 3.6 8.2 1.6 1.6 0 0 1 5.5 6.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="fx-cta-call-label" data-i18n="nav_cta">Let's have a call</span>
      </a>
      <button class="fx-burger" id="fx-burger" type="button" aria-label="Open menu"><span></span><span></span><span></span></button>
    </div>
  </div>
  <nav class="fx-mobile-nav" id="fx-mobile-nav" aria-label="Mobile">
    <a href="/service" data-i18n="nav_services">Services</a>
    <a href="/hire" data-i18n="nav_hire">Hire engineers</a>
    <a href="/solutions" data-i18n="nav_solutions">Solutions</a>
    <a href="/insights" data-i18n="nav_insights">Insights</a>
    <a href="/about" data-i18n="nav_about">About</a>
    <a href="/contact" data-i18n="nav_cta">Let's have a call</a>
  </nav>
</header>
