---
import SeoHead from "./SeoHead.astro";
import Header from "./fx/Header.astro";
import Footer from "./fx/Footer.astro";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  keywords?: string[];
  noindex?: boolean;
  schema?: Record<string, unknown>[];
}

const { title, description, canonical, ogImage, keywords, noindex, schema } = Astro.props;
const wa = "https://wa.me/" + site.phone.replace(/[^0-9]/g, "");
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      keywords={keywords}
      noindex={noindex}
      schema={schema}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/assets/img/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/img/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="/assets/css/fx.css" />
  </head>
  <body>
    <div class="fx-scrollbar" aria-hidden="true"></div>
    <Header />
    <main><slot /></main>
    <Footer />

    <a class="fx-wa" href={wa} target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.5 14.1c-.2.6-1.2 1.2-1.7 1.2-.4 0-1 .1-3.2-.9-2.7-1.2-4.4-4-4.5-4.2-.1-.2-1.1-1.4-1.1-2.7s.7-1.9.9-2.1c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.4 2.6 1.6.2.1.4.1.6-.1l.7-.8c.2-.2.3-.2.6-.1l1.9.9c.3.2.5.2.6.4.1.1.1.7-.1 1.3Z"/></svg>
    </a>

    <script is:inline src="/assets/js/fx-home.js" defer></script>
  </body>
</html>
