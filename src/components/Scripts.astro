---
interface Props {
  particles?: boolean;
}

const { particles = false } = Astro.props;
---

{particles && <script is:inline src="/assets/js/plugins/particles.min.js"></script>}
{
  particles && (
    <script is:inline>
      particlesJS.load('particles-js', '/assets/js/plugins/particlesjs-config.json');
    </script>
  )
}
<script is:inline src="/assets/js/plugins/jquery-3.6.0.min.js" defer></script>
<script is:inline src="/assets/js/plugins/isotope.pkg.min.js" defer></script>
<script is:inline src="/assets/js/plugins/jquery.slick.min.js" defer></script>
<script is:inline src="/assets/js/plugins/jquery.counter.min.js" defer></script>
<script is:inline src="/assets/js/plugins/lightgallery.min.js" defer></script>
<script is:inline src="/assets/js/plugins/wow.min.js" defer></script>
<script is:inline src="/assets/js/plugins/gsap.min.js" defer></script>
<script is:inline src="/assets/js/main.js" defer></script>
